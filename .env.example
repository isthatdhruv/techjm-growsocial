# ===========================================
# TechJM MVP — Environment Variables
# ===========================================

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/techjm
DB_ENCRYPTION_KEY=generate-a-32-byte-hex-key-here

# Redis
REDIS_URL=redis://localhost:6379

# Firebase
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
FIREBASE_ADMIN_SERVICE_ACCOUNT_KEY=

# AI Provider Keys (user-provided via BYOK, but platform needs these for testing)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
XAI_API_KEY=
DEEPSEEK_API_KEY=
REPLICATE_API_KEY=

# Social OAuth
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:3000/api/auth/linkedin/callback
LINKEDIN_ENABLE_ORGANIZATION_SCOPES=false
X_CLIENT_ID=
X_CLIENT_SECRET=
X_REDIRECT_URI=http://localhost:3000/api/auth/x/callback

# Postiz
POSTIZ_API_URL=http://localhost:5000
POSTIZ_API_KEY=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Telegram Notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Google Sheets
GOOGLE_SHEETS_WEB_APP_URL=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
